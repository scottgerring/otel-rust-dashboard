{# Reusable metric card partial.
   Args: id, title, value, subtitle (optional), chart_id (optional), color (optional), tooltip (optional)
#}
<div class="card" id="card-{{ id }}">
  <div class="card-header">
    <h3>{{ title }}</h3>
    {% if tooltip %}
    <span class="card-info" tabindex="0">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
      <span class="card-tooltip">{{ tooltip }}</span>
    </span>
    {% endif %}
  </div>
  <div class="card-body">
    <div class="card-value">{{ value if value is not none else "—" }}</div>
    {% if subtitle %}
    <div class="card-subtitle">{{ subtitle }}</div>
    {% endif %}
    {% if chart_id %}
    <div class="card-chart">
      <canvas id="{{ chart_id }}" height="80"></canvas>
    </div>
    {% endif %}
  </div>
</div>
